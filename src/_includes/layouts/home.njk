    <a class="home-card home-card-sets" href="{{ '/sets/' | url }}">
      <div class="home-card-overlay">
        <h2>Seiteanna</h2>
        <p>Treoracha, nótaí, & físeáin do gach seit.</p>
      </div>
    </a>

    <a class="home-card home-card-add" href="{{ '/glac-pairt/' | url }}">
      <div class="home-card-overlay">
        <h2>Glac Páirt</h2>
        <p>Aimsigh rang i do cheantar nó cuir do rang féin leis an léarscáil.</p>
      </div>
    </a>

  </div>
</section>


  </main>
