---
navClass: navbar-content
---
<!DOCTYPE html>
<html lang="ga">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} | {{ site.title }}</title>
  <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
</head>
<body>
  <main>
    {% include "partials/nav.njk" %}

    <section class="sets-page">
      <header class="sets-page-header">
        <h1 class="sets-page-title">{{ title }}</h1>
        <p class="sets-page-intro">Cuardaigh le teideal nó contae, nó cliceáil ar mharcóir ar an léarscáil.</p>

        <div class="sets-search">
          <label for="set-search" class="visually-hidden">Cuardaigh</label>
          <input type="text" id="set-search" class="sets-search-input" placeholder="Cuardaigh seit (teideal nó contae)...">
        </div>

      </header>

      <div class="sets-page-body">
        <aside class="sets-page-map" aria-label="Léarscáil">
          <div id="sets-ireland-map" class="ireland-map ireland-map--compact" role="img" aria-label="Léarscáil d'Éirinn le seiteanna"></div>
        </aside>

        <section class="sets-page-results" aria-label="Torthaí">
          <div class="sets-results-meta">
            <span id="sets-count" class="sets-count"></span>
          </div>

          <ul class="sets-results-list" id="sets-list">
            {% for set in collections.sets %}
            <li class="sets-result"
                data-title="{{ set.data.title | lower }}"
                data-county="{{ set.data.county | lower }}"
                data-url="{{ set.url | url }}"
                data-display-title="{{ set.data.title }}"
                data-display-county="{{ set.data.county }}"
                data-featured="{% if set.data.featured %}true{% else %}false{% endif %}">
              <a class="sets-result-link" href="{{ set.url | url }}">
                <span class="sets-result-title">{{ set.data.title }}</span>
              </a>
            </li>
            {% endfor %}
          </ul>

          <p class="sets-empty" id="no-results" style="display: none;">Toradh ar bith.</p>

          <div class="sets-page-actions">
            <a class="sets-browse-all" href="{{ '/seiteanna/uile/' | url }}">Brabhsáil na seiteanna uile</a>
          </div>
        </section>
      </div>
    </section>
    
    {% include "partials/footer.njk" %}

    <script src="{{ '/js/vendor/d3.min.js' | url }}"></script>
    <script>
      (function() {
        const searchInput = document.getElementById('set-search');
        const setsList = document.getElementById('sets-list');
        const resultsPane = document.querySelector('.sets-page-results');
        const countEl = document.getElementById('sets-count');
        const noResults = document.getElementById('no-results');
        const setItems = Array.from(setsList.querySelectorAll('li'));
        let lastQuery = '';

        // Prepare data for map + filtering.
        const sets = setItems.map((item) => ({
          title: (item.getAttribute('data-display-title') || '').toString(),
          county: (item.getAttribute('data-display-county') || '').toString(),
          url: (item.getAttribute('data-url') || '').toString(),
          titleKey: (item.getAttribute('data-title') || '').toString(),
          countyKey: (item.getAttribute('data-county') || '').toString(),
          featured: item.getAttribute('data-featured') === 'true'
        }));

        const mapRootEl = document.getElementById('sets-ireland-map');

        // Render compact Ireland map and expose marker update API.
        (function initSetsMap() {
          if (!mapRootEl || !window.d3) return;

          const counties = {{ counties | dump | safe }};

          // Minimal TopoJSON helpers (avoid extra dependency).
          function topoTransformPoint(transform, point) {
            if (!transform) return point;
            const scale = transform.scale || [1, 1];
            const translate = transform.translate || [0, 0];
            return [
              point[0] * scale[0] + translate[0],
              point[1] * scale[1] + translate[1]
            ];
          }

          function topoArcsToCoordinates(arcs, topology) {
            const { arcs: topoArcs, transform } = topology;
            let x = 0, y = 0;
            const coords = [];
            for (const arcIndexRaw of arcs) {
              const arcIndex = arcIndexRaw < 0 ? ~arcIndexRaw : arcIndexRaw;
              const arc = topoArcs[arcIndex];
              const points = [];
              x = 0; y = 0;
              for (const [dx, dy] of arc) {
                x += dx; y += dy;
                points.push(topoTransformPoint(transform, [x, y]));
              }
              if (arcIndexRaw < 0) points.reverse();
              if (coords.length) points.shift();
              coords.push(...points);
            }
            return coords;
          }

          function topoGeometryToGeometry(topology, geom) {
            if (geom.type === 'Polygon') {
              return {
                type: 'Polygon',
                coordinates: geom.arcs.map((ring) => [ ...topoArcsToCoordinates(ring, topology) ])
              };
            }
            if (geom.type === 'MultiPolygon') {
              return {
                type: 'MultiPolygon',
                coordinates: geom.arcs.map((poly) =>
                  poly.map((ring) => [ ...topoArcsToCoordinates(ring, topology) ])
                )
              };
            }
            return { type: geom.type, coordinates: [] };
          }

          function topoObjectToGeoJSON(topology, objectName) {
            const obj = topology.objects[objectName];
            if (!obj) throw new Error('Missing TopoJSON object: ' + objectName);

            if (obj.type === 'GeometryCollection') {
              return {
                type: 'FeatureCollection',
                features: obj.geometries.map((g) => ({
                  type: 'Feature',
                  properties: g.properties || {},
                  geometry: topoGeometryToGeometry(topology, g)
                }))
              };
            }

            return {
              type: 'FeatureCollection',
              features: [{
                type: 'Feature',
                properties: obj.properties || {},
                geometry: topoGeometryToGeometry(topology, obj)
              }]
            };
          }

          function jitterLatLng(baseLat, baseLng, index, total) {
            if (total <= 1) return [baseLat, baseLng];
            const radiusKm = 8;
            const angle = (2 * Math.PI * index) / total;
            const dLat = (radiusKm / 111) * Math.sin(angle);
            const dLng = (radiusKm / (111 * Math.cos((baseLat * Math.PI) / 180))) * Math.cos(angle);
            return [baseLat + dLat, baseLng + dLng];
          }

          function makeMarkerPoints(setsToPlot) {
            const byCounty = new Map();
            setsToPlot
              .slice()
              .sort((a, b) => (a.title || '').localeCompare(b.title || '', 'ga'))
              .forEach((s) => {
                const c = (s.county || '').trim();
                if (!byCounty.has(c)) byCounty.set(c, []);
                byCounty.get(c).push(s);
              });

            const markerPoints = [];
            for (const [countyName, countySets] of byCounty.entries()) {
              const centroid = counties[countyName];
              if (!centroid) continue;
              countySets.forEach((s, i) => {
                const [lat, lng] = jitterLatLng(centroid.lat, centroid.lng, i, countySets.length);
                markerPoints.push({ title: s.title, url: s.url, lat, lng });
              });
            }
            return markerPoints;
          }

          let svg, projection, tooltipEl;

          function renderBase(topology) {
            const objectKey = topology.objects.counties
              ? 'counties'
              : topology.objects.irish_counties
              ? 'irish_counties'
              : Object.keys(topology.objects)[0];

            const geo = topoObjectToGeoJSON(topology, objectKey);

            const width = mapRootEl.clientWidth || 520;
            const height = Math.max(260, Math.round(width * 1.05));

            mapRootEl.innerHTML = '';
            mapRootEl.style.position = 'relative';

            tooltipEl = document.createElement('div');
            tooltipEl.className = 'ireland-map-tooltip';
            tooltipEl.style.display = 'none';
            mapRootEl.appendChild(tooltipEl);

            svg = d3
              .select(mapRootEl)
              .append('svg')
              .attr('class', 'ireland-map-svg')
              .attr('viewBox', `0 0 ${width} ${height}`)
              .attr('preserveAspectRatio', 'xMidYMid meet');

            projection = d3.geoMercator();
            const path = d3.geoPath(projection);
            projection.fitSize([width, height], geo);

            svg
              .append('g')
              .attr('class', 'ireland-counties')
              .selectAll('path')
              .data(geo.features)
              .join('path')
              .attr('d', path)
              .attr('class', 'ireland-county');

            // Marker group placeholder
            svg.append('g').attr('class', 'ireland-set-markers');
          }

          function showTooltip(event, title) {
            tooltipEl.textContent = title;
            tooltipEl.style.display = 'block';
            moveTooltip(event);
          }

          function moveTooltip(event) {
            const bounds = mapRootEl.getBoundingClientRect();
            const x = event.clientX - bounds.left;
            const y = event.clientY - bounds.top;
            tooltipEl.style.left = (x + 10) + 'px';
            tooltipEl.style.top = (y - 10) + 'px';
          }

          function hideTooltip() {
            tooltipEl.style.display = 'none';
          }

          function updateMarkers(setsToPlot) {
            if (!svg || !projection) return;

            const points = makeMarkerPoints(setsToPlot);
            const g = svg.select('g.ireland-set-markers');

            const sel = g
              .selectAll('a')
              .data(points, (d) => d.url)
              .join(
                (enter) => {
                  const a = enter
                    .append('a')
                    .attr('xlink:href', (d) => d.url)
                    .attr('href', (d) => d.url)
                    .on('click', function(event, d) {
                      event.preventDefault();
                      window.location.href = d.url;
                    });

                  a.append('circle')
                    .attr('class', 'ireland-set-marker')
                    .attr('r', 5.25);

                  return a;
                },
                (update) => update,
                (exit) => exit.remove()
              );

            sel.select('circle')
              .attr('cx', (d) => projection([d.lng, d.lat])[0])
              .attr('cy', (d) => projection([d.lng, d.lat])[1]);

            sel
              .on('mouseenter', function(event, d) { showTooltip(event, d.title); })
              .on('mousemove', function(event) { moveTooltip(event); })
              .on('mouseleave', function() { hideTooltip(); });
          }

          // Expose API for the search filter to call.
          window.__setsMap = { updateMarkers };

          fetch({{ ('/data/ireland-counties.topojson' | url) | dump | safe }})
            .then((r) => r.json())
            .then((topology) => {
              renderBase(topology);
              updateMarkers(sets);
            })
            .catch((e) => console.error('[seit.ie] Failed to load sets map data:', e));
        })();

        function filterSets() {
          const query = searchInput.value.toLowerCase().trim();
          let visibleCount = 0;
          const visible = [];

          setItems.forEach(item => {
            const title = item.getAttribute('data-title');
            const county = item.getAttribute('data-county');
            const isFeatured = item.getAttribute('data-featured') === 'true';
            const matchesSearch = !query || title.includes(query) || county.includes(query);
            const matches = query ? matchesSearch : isFeatured;
            
            item.style.display = matches ? '' : 'none';
            if (matches) {
              visibleCount++;
              const url = item.getAttribute('data-url') || '';
              const found = sets.find((s) => s.url === url);
              if (found) visible.push(found);
            }
          });

          noResults.style.display = visibleCount === 0 && query ? 'block' : 'none';
          if (countEl) {
            countEl.textContent = visibleCount + ' seiteanna';
          }

          // Update map markers.
          if (mapRootEl && window.__setsMap && typeof window.__setsMap.updateMarkers === 'function') {
            window.__setsMap.updateMarkers(visible);
          }

          // Make filtering more obvious on mobile (flash + scroll to results).
          if (resultsPane) {
            resultsPane.classList.remove('sets-page-results--updated');
            // Force reflow so the class re-add animates even on repeated input.
            void resultsPane.offsetWidth;
            resultsPane.classList.add('sets-page-results--updated');
            window.setTimeout(() => resultsPane.classList.remove('sets-page-results--updated'), 350);
          }

          const isMobileStack = window.matchMedia && window.matchMedia('(max-width: 980px)').matches;
          if (isMobileStack && query && query !== lastQuery) {
            const anchor = countEl || resultsPane;
            if (anchor && typeof anchor.scrollIntoView === 'function') {
              anchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }
          lastQuery = query;
        }

        searchInput.addEventListener('input', filterSets);
        filterSets();
      })();
    </script>
  </main>
</body>
</html>
